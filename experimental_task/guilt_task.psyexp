        <Param val="if ((Object.getPrototypeOf(memory_question_resp.rt) === list)) {&amp;#10;    fixation_2_duration = 1;&amp;#10;} else {&amp;#10;    fixation_2_duration = (1 + (Math.floor((60 * (4 - memory_question_resp.rt))) / 60));&amp;#10;}&amp;#10;" valType="extendedCode" updates="constant" name="End JS Routine"/>
