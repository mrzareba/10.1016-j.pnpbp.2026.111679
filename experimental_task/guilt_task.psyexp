        <Param val="" valType="code" updates="constant" name="stopVal"/>
        <Param val="True" valType="bool" updates="None" name="syncScreenRefresh"/>
        <Param val="Cuando en la pantalla aparezcan las palabras clave relacionadas con sus recuerdos, revívalo y preste atención a los sentimientos relacionados.&amp;#10;&amp;#10;Luego, recuerde responder la pregunta de las circunstancias del evento antes de 4 segundos.&amp;#10;&amp;#10;En la tarea aritmética elija el número correcto en menos de 2 segundos.&amp;#10;&amp;#10;Cuando haya leído esta instrucción, presione cualquier botón para avanzar. El experimento comenzará pronto." valType="str" updates="constant" name="text"/>
        <Param val="from exp settings" valType="str" updates="None" name="units"/>
        <Param val="" valType="num" updates="constant" name="wrapWidth"/>
      </TextComponent>
